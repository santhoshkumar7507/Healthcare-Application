# VitaLens Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/vitalens
# For local SQLite (no setup needed):
# DATABASE_URL=sqlite:///./vitalens.db

# ── JWT Auth ──────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Blockchain (Ethereum Sepolia Testnet) ─────────────
BLOCKCHAIN_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
WALLET_ADDRESS=0xYourWalletAddress
WALLET_PRIVATE_KEY=your_private_key_never_commit_this

# ── ML Model ──────────────────────────────────────────
MODEL_PATH=ml/saved_models/vitalens_v1.pt

# ── Google Maps (for live hospital locations) ─────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── App ───────────────────────────────────────────────
DEBUG=True
APP_NAME=VitaLens
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500
